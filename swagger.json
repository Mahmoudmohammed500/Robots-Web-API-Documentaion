{
  "openapi": "3.0.3",
  "info": {
    "title": "Robots Web API",
    "description": "Documentation for Users API",
    "version": "1.0.0"
  },
  "servers": [{ "url": "http://localhost/robots_api/api" }],
  "paths": {
    "/users": {
      "get": {
        "summary": "Get all users",
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {}
            }
          }
        }
      },
      "post": {
        "summary": "Create a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "Username": { "type": "string" },
                  "Password": { "type": "string" },
                  "TelephoneNumber": { "type": "string" },
                  "ProjectName": { "type": "string" }
                },
                "required": [
                  "Username",
                  "Password",
                  "TelephoneNumber",
                  "ProjectName"
                ]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created" },
          "400": { "description": "Missing required fields" }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "summary": "Get a user by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "User found" },
          "404": { "description": "User not found" }
        }
      },
      "put": {
        "summary": "Update a user by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "Username": { "type": "string" },
                  "Password": { "type": "string" },
                  "TelephoneNumber": { "type": "string" },
                  "ProjectName": { "type": "string" }
                },
                "required": [
                  "Username",
                  "Password",
                  "TelephoneNumber",
                  "ProjectName"
                ]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "User updated" },
          "404": { "description": "User not found" }
        }
      },
      "delete": {
        "summary": "Delete a user by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "User deleted" },
          "404": { "description": "User not found" }
        }
      }
    }
  }
}
