      },
      "put": {
        "tags": ["Robots"],
        "summary": "Update a robot by ID",
        "description": "⚠️ Logic Note : If `isTrolley` = `false`, then the `car` object should be empty `{}` and system will do it automoticaly by sql and js.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Robot" }
            }
          }
        },
        "responses": {
          "200": { "description": "Robot updated successfully" }
        }
      },
      "delete": {
        "tags": ["Robots"],
        "summary": "Delete a robot by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Robot deleted successfully" }
        }
      }
    },
    "/robots/": {
      "delete": {
        "tags": ["Robots"],
        "summary": "Delete all robots",
        "responses": {
          "200": { "description": "All robots deleted successfully" }
        }
      }
    },

