  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "Username": { "type": "string", "example": "Ahmed" },
          "Password": { "type": "string", "example": "123456" },
          "TelephoneNumber": { "type": "string", "example": "+201234567890" },
          "ProjectName": { "type": "string", "example": "AI Robot" }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "ProjectName": { "type": "string", "example": "Airport Bot" },
          "Description": {
            "type": "string",
            "example": "Smart robot for airport security"
          },
          "Location": { "type": "string", "example": "Saudi Arabia" },
          "Image": { "type": "string", "example": "uploads/robot.jpg" }
        }
      },
      "Robot": {
        "type": "object",
        "properties": {
          "RobotName": { "type": "string", "example": "cccccccccccccccc  New" },
          "Image": { "type": "string", "example": "warehousebot.png" },
          "projectId": { "type": "integer", "example": 10 },
          "mqttUrl": {
            "type": "string",
            "example": "mqtt://192.168.1.50:1883"
          },
          "isTrolley": { "type": "boolean", "example": true },
          "Sections": {
            "type": "object",
            "properties": {
              "main": {
                "type": "object",
                "properties": {
                  "Voltage": { "type": "number", "example": 24 },
                  "Cycles": { "type": "integer", "example": 500 },
                  "Status": { "type": "string", "example": "Running" },
                  "ActiveBtns": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "Name": { "type": "string", "example": "Forward" },
                        "id": { "type": "string", "example": "1" }
                      }
                    },
                    "example": [
                      { "Name": "Forward", "id": "1" },
                      { "Name": "stop", "id": "2" }
                    ]
                  },
                  "Topic_subscribe": {
                    "type": "string",
                    "example": "robot/main/in"
                  },
                  "Topic_main": {
                    "type": "string",
                    "example": "robot/main/out"
                  }
                }
              },
              "car": {
                "type": "object",
                "properties": {
                  "Voltage": { "type": "number", "example": 24 },
                  "Cycles": { "type": "integer", "example": 500 },
                  "Status": { "type": "string", "example": "Running" },
                  "ActiveBtns": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "Name": { "type": "string", "example": "Forward" },
                        "id": { "type": "string", "example": "1" }
                      }
                    },
                    "example": [
                      { "Name": "Forward", "id": "1" },
                      { "Name": "stop", "id": "2" }
                    ]
                  },
                  "Topic_subscribe": {
                    "type": "string",
                    "example": "robot/main/in"
                  },
                  "Topic_main": {
                    "type": "string",
                    "example": "robot/main/out"
                  }
                }
              }
            }
          }
        },
        "required": [
          "RobotName",
          "projectId",
          "mqttUrl",
          "isTrolley",
          "Sections"
        ],
        "example": {
          "RobotName": "cccccccccccccccc  New",
          "Image": "warehousebot.png",
          "projectId": 10,
          "mqttUrl": "mqtt://192.168.1.50:1883",
          "isTrolley": true,
          "Sections": {
            "main": {
              "Voltage": 24,
              "Cycles": 500,
              "Status": "Running",
              "ActiveBtns": [
                { "Name": "Forward", "id": "1" },
                { "Name": "stop", "id": "2" }
              ],
              "Topic_subscribe": "robot/main/in",
              "Topic_main": "robot/main/out"
            },
            "car": {
              "Voltage": 24,
              "Cycles": 500,
              "Status": "Running",
              "ActiveBtns": [
                { "Name": "Forward", "id": "1" },
                { "Name": "stop", "id": "2" }
              ],
              "Topic_subscribe": "robot/main/in",
              "Topic_main": "robot/main/out"
            }
          }
        }
      },
      "Button": {
        "type": "object",
        "properties": {
          "BtnName": { "type": "string", "example": "Start" },
          "RobotId": { "type": "integer", "example": 1 },
          "Color": { "type": "string", "example": "#4CAF50" },
          "Operation": { "type": "string", "example": "/start" }
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "projectId": { "type": "integer", "example": 5 },
          "robotId": { "type": "integer", "example": 3 },
          "message": { "type": "string", "example": "Battery level low" },
          "type": { "type": "string", "example": "alert" },
          "date": { "type": "string", "example": "2025-11-05" },
          "time": { "type": "string", "example": "14:25:00" }
        }
      },
      "Log": {
        "type": "object",
        "properties": {
          "projectId": { "type": "integer", "example": 5 },
          "robotId": { "type": "integer", "example": 3 },
          "message": {
            "type": "string",
            "example": "Robot connected successfully"
          },
          "type": { "type": "string", "example": "info" },
          "date": { "type": "string", "example": "2025-11-05" },
          "time": { "type": "string", "example": "14:26:30" }
        }
      }
    }
  }
}
